{
  "name": "@lmb/kitsconcerto",
  "version": "0.1.0",
  "description": "Cross-platform UI component package for React (web) and React Native",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/web/index.d.ts",
      "browser": "./dist/web/index.js",
      "import": "./dist/web/index.js",
      "require": "./dist/web/index.cjs",
      "default": "./dist/web/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js",
      "require": "./dist/web/index.cjs",
      "default": "./dist/web/index.js"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.js",
      "require": "./dist/native/index.cjs",
      "default": "./dist/native/index.js"
    },
    "./primeflex": {
      "require": "./dist/native/primeflex.js",
      "default": "./dist/native/primeflex.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/web/index.cjs",
  "module": "./dist/web/index.js",
  "types": "./dist/web/index.d.ts",
  "react-native": "./dist/native/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:web": "rollup -c rollup.web.config.mjs && rollup -c rollup.dts.config.mjs && node scripts/rename-dts.js && yalc publish --force",
    "dev:web": "rollup -c rollup.web.config.mjs -w",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.0",
    "axios": "^1.11.0",
    "countries-list": "^3.1.1",
    "libphonenumber-js": "^1.12.38",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "normalize-css-color": "^1.0.2",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.61.1",
    "swr": "^2.3.4",
    "tslib": "^2.6.0",
    "usehooks-ts": "^3.1.1",
    "yup": "^1.6.1",
    "yup-password": "^0.4.0"
  },
  "peerDependencies": {
    "chart.js": "^4.5.0",
    "framer-motion": "^12.23.11",
    "jspdf": "^3.0.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": ">=0.70.0",
    "react-router-dom": "^7.9.4",
    "styled-components": "^6.1.19"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "primereact": {
      "optional": true
    },
    "primeflex": {
      "optional": true
    },
    "primeicons": {
      "optional": true
    },
    "styled-components": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    },
    "framer-motion": {
      "optional": true
    },
    "jspdf": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "yalcSig": "e1f5ea35c37b4704332050185fda961c"
}
