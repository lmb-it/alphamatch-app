{
  "extends": "@react-native/typescript-config",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleSuffixes": [".native", ""],
    "verbatimModuleSyntax": false,
    "jsx": "react-native",
    "baseUrl": ".",
    "types": ["react", "react-native"],
    "paths": {
      "@lmb/kitsconcerto": ["./node_modules/@lmb/kitsconcerto/dist/native/index.d.ts"],
      "@lmb/kitsconcerto/*": ["./node_modules/@lmb/kitsconcerto/*"],
      "@/*": ["./*"],
      "@src/*": ["./src/*"],
      "tailwind.config": ["./tailwind.config.js"]
    }
  }
}
