# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!
use_frameworks! :linkage => :static
$RNFirebaseAsStaticFramework = true

target 'AlphaMatch' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
                    
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Remove duplicate linker flags (e.g. -lc++) across all targets
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS']
        if ldflags.is_a?(Array)
          config.build_settings['OTHER_LDFLAGS'] = ldflags.uniq
        end
      end
    end

    # Fix Xcode 26: duplicate modulemap definitions cause
    # "Redefinition of module" build errors. Deduplicate by replacing
    # the secondary modulemap with a symlink to the primary one.
    dedup = [
      # [directory, primary_prefix, secondary_prefix]
      ['react_runtime', 'React-RuntimeCore', 'React-jsitooling'],
      ['ReactCommon',   'ReactCommon',        'React-RuntimeApple'],
    ]
    dedup.each do |dir_name, primary, secondary|
      dir = File.join(installer.sandbox.root, 'Headers', 'Public', dir_name)
      next unless File.directory?(dir)
      %w[.modulemap -umbrella.h].each do |ext|
        src = File.join(dir, "#{primary}#{ext}")
        dup = File.join(dir, "#{secondary}#{ext}")
        if File.exist?(dup) && File.exist?(src)
          File.delete(dup)
          File.symlink(src, dup)
        end
      end
    end
  end
end
